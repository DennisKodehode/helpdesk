{
  "name": "helpdesk",
  "private": true,
  "workspaces": ["client", "server", "core"],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "test:e2e": "bun --env-file server/.env.test playwright test --pass-with-no-tests",
    "test:e2e:ui": "bun --env-file server/.env.test playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0"
  }
}
